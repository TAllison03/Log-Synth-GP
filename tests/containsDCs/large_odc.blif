# out0 = sel0 == 1 ? (a + b) : (c + d)
# out1 = sel1 == 1 ? (c + d) : (e + f)
# out2 = en * (a + b)
# out3 = en * (a * g)

.model large_odc
.inputs sel0 sel1 en a b c d e f g
.outputs out0 out1 out2 out3

# n_ab = a OR b
.names a b n_ab
1- 1
-1 1

# n_cd = c OR d
.names c d n_cd
1- 1
-1 1

# n_ef = e OR f
.names e f n_ef
1- 1
-1 1

# n_ag = a AND g
.names a g n_ag
11 1

# out0 = mux(sel0, n_ab, n_cd)
# sel0=1 -> n_ab;  sel0=0 -> n_cd
.names sel0 n_ab n_cd out0
0 - 1 1
1 1 - 1

# out1 = mux(sel1, n_cd, n_ef)
# sel1=1 -> n_cd;  sel1=0 -> n_ef
.names sel1 n_cd n_ef out1
0 - 1 1
1 1 - 1

# out2 = en AND n_ab
.names en n_ab out2
11 1

# out3 = en AND n_ag
.names en n_ag out3
11 1

.end
